# ──────────────────────────────────────────────────────────────
# NOX — environment configuration
# Copy this file to `.env.local` and fill in your values.
# ──────────────────────────────────────────────────────────────

# Public site URL (used for SEO metadata, canonical URLs, sitemap)
NEXT_PUBLIC_SITE_URL=https://nox.store

# ─── Shopify Storefront API ───────────────────────────────────
# Leave these blank to run on the bundled dummy catalog (demo mode).
# Fill them in to switch the storefront over to live Shopify data.
#
# 1. Shopify Admin → Settings → Apps and sales channels → Develop apps
# 2. Create an app, enable the Storefront API, grab the access token.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_STOREFRONT_API_VERSION=2024-07

# Optional: secret used to validate Shopify webhooks (revalidation)
SHOPIFY_REVALIDATION_SECRET=
